    "check-sop": "node lib/analize-text.js --url https://raw.githubusercontent.com/develjs/words/master/public/static/my-sophomore-year.txt --save public/static/my-sophomore-year.json",
    "check-anne": "node lib/analize-text.js --url https://raw.githubusercontent.com/develjs/words/master/public/static/ann-from-green-gables.txt --save public/static/ann-from-green-gables.json"
  },
  "dependencies": {
